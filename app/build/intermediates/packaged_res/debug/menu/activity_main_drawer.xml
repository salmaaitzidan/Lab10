<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main_drawer.xml – Menu du panneau Navigation Drawer.

    Trois items de navigation :
    - nav_fragment1 : ouvre BlankFragment (fond rose)
    - nav_fragment2 : ouvre BlankFragment2 (fond bleu)
    - nav_list     : ouvre FragmentList (liste de 10 éléments)
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <group android:checkableBehavior="single">

        <item
            android:id="@+id/nav_fragment1"
            android:icon="@drawable/ic_home"
            android:title="@string/menu_fragment1" />

        <item
            android:id="@+id/nav_fragment2"
            android:icon="@drawable/ic_dashboard"
            android:title="@string/menu_fragment2" />

        <item
            android:id="@+id/nav_list"
            android:icon="@drawable/ic_list"
            android:title="@string/menu_fragment_list" />

    </group>

</menu>

<?xml version="1.0" encoding="utf-8"?>
<!--
    content_main.xml – Zone d'affichage des fragments.

    Le FrameLayout (id: contenu) est le conteneur cible des transactions
    de fragments. Chaque appel à replace(R.id.contenu, ...) remplace
    le fragment actuellement visible par le nouveau fragment sélectionné.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <!--
        FrameLayout conteneur des fragments.
        - match_parent : occupe tout l'espace disponible sous la toolbar
        - id="contenu" : référencé dans MainActivity pour les transactions
    -->
    <FrameLayout
        android:id="@+id/contenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
